# BattleTab Server Environment Variables
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://localhost:5432/battletab

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# OneSignal (email service)
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
