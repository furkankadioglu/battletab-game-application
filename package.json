{
  "name": "battletab",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "test": "jest --passWithNoTests --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern=unit --passWithNoTests --forceExit --detectOpenHandles",
    "test:integration": "jest --testPathPattern=integration --passWithNoTests --forceExit --detectOpenHandles",
    "test:visual": "node tests/visual/screenshot.test.js",
    "test:perf": "node tests/perf/benchmark.js",
    "build": "cd client && npm run build",
    "smoke": "bash tests/smoke.sh",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "jest": "^29.7.0",
    "puppeteer": "^24.39.1"
  }
}
